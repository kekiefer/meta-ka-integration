From f7ebd74d98c89b5ba0c3ceedf415e0a55eb79cec Mon Sep 17 00:00:00 2001
From: Kurt Kiefer <kekiefer@gmail.com>
Date: Thu, 9 Apr 2026 09:56:37 -0700
Subject: [PATCH] Don't try to import numpy-native during setup

Upstream-Status: Inappropriate [OE specific]
---
 setup.py | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/setup.py b/setup.py
index e02c7a9..721168f 100644
--- a/setup.py
+++ b/setup.py
@@ -65,7 +65,6 @@ def get_ext_options():
     If geos-config was not found, no additional paths are provided to the extension.
     It is still possible to compile in this case using custom arguments to setup.py.
     """
-    import numpy
 
     opts = {
         "define_macros": [
@@ -82,8 +81,9 @@ def get_ext_options():
         "libraries": [],
     }
 
-    if include_dir := numpy.get_include():
-        opts["include_dirs"].append(include_dir)
+    numpy_include = os.environ.get("NUMPY_INCLUDE_PATH")
+    if numpy_include:
+        opts["include_dirs"].append(numpy_include)
 
     # Without geos-config (e.g. MSVC), specify these two vars
     include_dir = os.environ.get("GEOS_INCLUDE_PATH")
-- 
2.34.1

